# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=changeme-use-a-strong-password

# Full connection string (for local dev, uses localhost; in Docker, uses container name)
DATABASE_URL=postgresql://entoto:changeme-use-a-strong-password@localhost:5432/entoto_farm

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Public URL of your server (no trailing slash)
NEXTAUTH_URL=https://yourdomain.com

# Optional: AI features
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Notifications — pre-seed the settings table on first deploy
# These can also be configured via the /settings page in the app
SMS_ETHIOPIA_TOKEN=API_KEY:SENDER_ID   # e.g. ZE6V155...:759
SMS_ETHIOPIA_BASE_URL=                  # leave blank for default
TELEGRAM_BOT_TOKEN=                     # from @BotFather
TELEGRAM_CHAT_ID=                       # chat/group ID to send alerts to

# Weather
TOMORROW_IO_API_KEY=                    # from tomorrow.io dashboard
